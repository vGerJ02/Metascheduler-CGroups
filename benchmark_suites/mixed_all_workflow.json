      "scheduler_type": "H",
      "name": "mixed-hadoop-randomwriter-${ts}",
      "path": "/usr/hdp/current/hadoop-mapreduce-client/hadoop-mapreduce-examples.jar",
      "options": "randomwriter -Dtest.randomwrite.total_bytes=21474836480 -Dtest.randomwrite.bytes_per_map=2147483648 -Dmapreduce.job.maps=10 -Dmapreduce.map.memory.mb=4096 -Dmapreduce.map.java.opts=-Xmx3276m /user/gjaimejuan/mixed/randomwriter",
      "pre_steps": [
        {
          "type": "hdfs_rm",
