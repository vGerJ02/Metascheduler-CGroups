{
  "version": 1,
  "name": "cgroups-best-effort-mixed-all-workflow",
  "defaults": {
    "queue": 1,
    "delay_after_seconds": 3,
    "on_error": "stop",
    "hdfs_bin": "hdfs"
  },
  "jobs": [
    {
      "id": "hadoop-nnbench-create",
      "scheduler_type": "H",
      "name": "mixed-hadoop-nnbench-create-${ts}",
      "path": "/usr/hdp/current/hadoop-mapreduce-client/hadoop-mapreduce-client-jobclient-tests.jar",
      "options": "nnbench -operation create_write -maps 16 -reduces 4 -blockSize 1 -bytesToWrite 512 -numberOfFiles 5000 -replicationFactorPerFile 3 -baseDir /user/gjaimejuan/mixed/nnbench",
      "pre_steps": [
        {
          "type": "hdfs_rm",
          "path": "/user/gjaimejuan/mixed/nnbench"
        },
        {
          "type": "hdfs_mkdir",
          "path": "/user/gjaimejuan/mixed"
        }
      ]
    },
    {
      "id": "sge-genesis-cryoem-all-atom",
      "scheduler_type": "S",
      "name": "mixed-genesis_cryoEM_All_atom-${ts}",
      "path": "/home/mpiuser/benchmarks/benchs_install/genesis/jobs/genesis_cryoEM_All_atom.sh",
      "qsub_options": "-v InputData=inp_med -pe mpi 64",
      "depends_on": [
        "hadoop-nnbench-create"
      ]
    },
    {
      "id": "hadoop-nnbench-read",
      "scheduler_type": "H",
      "name": "mixed-hadoop-nnbench-read-${ts}",
      "path": "/usr/hdp/current/hadoop-mapreduce-client/hadoop-mapreduce-client-jobclient-tests.jar",
      "options": "nnbench -operation open_read -maps 16 -reduces 4 -numberOfFiles 5000 -baseDir /user/gjaimejuan/mixed/nnbench",
      "depends_on": [
        "sge-genesis-cryoem-all-atom"
      ]
    },
    {
      "id": "sge-genesis-cryoem-go-model",
      "scheduler_type": "S",
      "name": "mixed-genesis_cryoEM_Go_model-${ts}",
      "path": "/home/mpiuser/benchmarks/benchs_install/genesis/jobs/genesis_cryoEM_Go_model.sh",
      "qsub_options": "-v InputData=inp_med -pe mpi 64",
      "depends_on": [
        "hadoop-nnbench-read"
      ]
    },
    {
      "id": "hadoop-dfsio-write",
      "scheduler_type": "H",
      "name": "mixed-hadoop-dfsio-write-${ts}",
      "path": "/usr/hdp/current/hadoop-mapreduce-client/hadoop-mapreduce-client-jobclient-tests.jar",
      "options": "TestDFSIO -write -nrFiles 20 -fileSize 4096 -resFile /tmp/mixed_dfsio_write.txt",
      "pre_steps": [
        {
          "type": "hdfs_rm",
          "path": "/benchmarks/TestDFSIO"
        }
      ],
      "depends_on": [
        "sge-genesis-cryoem-go-model"
      ]
    },
    {
      "id": "sge-genesis-dna-cutoff",
