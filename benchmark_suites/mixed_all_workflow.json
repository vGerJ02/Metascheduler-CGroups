      "path": "/usr/hdp/current/hadoop-mapreduce-client/hadoop-mapreduce-examples.jar",
      "options": "pi -Dmapreduce.map.memory.mb=2048 -Dmapreduce.map.java.opts=-Xmx1638m 80 10000000",
