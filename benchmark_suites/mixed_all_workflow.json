      "depends_on": [
        "hadoop-dfsio-write"
      ]
    },
    {
      "id": "hadoop-dfsio-read",
      "scheduler_type": "H",
      "name": "mixed-hadoop-dfsio-read-${ts}",
      "path": "/usr/hdp/current/hadoop-mapreduce-client/hadoop-mapreduce-client-jobclient-tests.jar",
      "options": "TestDFSIO -read -nrFiles 20 -fileSize 4096 -resFile /tmp/mixed_dfsio_read.txt",
